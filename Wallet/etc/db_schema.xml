<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/db_schema.xsd">
    <table name="transactions" resource="default" engine="innodb" comment="Transactions Table">
        <column name="id" xsi:type="int" unsigned="true" nullable="false" identity="true" comment="Transaction ID"/>
        <column name="customer_id" xsi:type="int" unsigned="true" nullable="false" comment="Customer ID"/>
        <column name="transaction_type" xsi:type="varchar" length="10" nullable="false"
                comment="Transaction Type (credit/debit)"/>
        <column name="amount" xsi:type="decimal" precision="12" scale="2" nullable="false"
                comment="Transaction Amount"/>
        <column name="transaction_status" xsi:type="varchar" length="10" nullable="false"
                comment="Transaction Status (pending/completed/failed)"/>
        <column name="otp_code" xsi:type="varchar" length="6" nullable="true" comment="OTP Code"/>
        <column name="admin_action" xsi:type="varchar" length="20" nullable="true"
                comment="Admin Action (added_by_admin, remove_by_admin, refund, reward)"/>
        <column name="remarks" xsi:type="varchar" length="255" nullable="true" comment="Transaction Remarks"/>
        <column name="created_at" xsi:type="timestamp" nullable="false" default="CURRENT_TIMESTAMP"
                comment="Created At"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="WALLET_TRANSACTION_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
                    table="wallet_transactions" column="customer_id"
                    referenceTable="customer_entity" referenceColumn="entity_id" onDelete="CASCADE"
        />
    </table>
</schema>
