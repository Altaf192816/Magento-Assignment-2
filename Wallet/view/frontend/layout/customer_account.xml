<?xml version="1.0"?>
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework/View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="customer_account_navigation">
            <block class="Magento\Customer\Block\Account\SortLinkInterface" name="customer-account-wallet-link" after="wishlist">
                <arguments>
                    <argument name="path" xsi:type="string">wallet/index/mywallet</argument>
                    <argument name="label" xsi:type="string">My Wallet</argument>
                </arguments>
            </block>

            <block class="Magento\Customer\Block\Account\SortLinkInterface" name="customer-account-wallet-transactions-link" after="customer-account-wallet-link">
                <arguments>
                    <argument name="path" xsi:type="string">wallet/index/wallettransaction</argument>
                    <argument name="label" xsi:type="string">My Wallet Transactions</argument>
                </arguments>
            </block>

            <block class="Magento\Customer\Block\Account\SortLinkInterface" name="customer-account-transfer-money-link" after="customer-account-wallet-transactions-link">
                <arguments>
                    <argument name="path" xsi:type="string">wallet/index/transfermoney</argument>
                    <argument name="label" xsi:type="string">Transfer Money</argument>
                </arguments>
            </block>
        </referenceBlock>
    </body>
</page>
