            <?= $block->escapeHtml($walletBalance) ?> <?= __('Credits') ?>
        </strong>
    </div>

    <label class="admin__field-label"><span
            class="admin__field-label-text"><?= __('Transaction Operations') ?></span></label>
    <div>
