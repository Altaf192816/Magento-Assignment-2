</div>

<style>
    .tab {
        display: none;
        margin-top: 16px;
    }

    .admin__field-control {
        margin-bottom: 16px;
    }

    .admin__field-label-text {
        font-size: 3rem;
        margin-bottom: 16px;
    }

    .admin__field-control {
        font-size: 2rem;
        color: green;
    }

    .wallet-transfer-form {
        max-width: 400px;
        margin: 20px 0;
    }

    .form-group {
        margin-bottom: 15px;
    }

    .label {
        font-weight: bold;
    }

    .form-group input, .form-group select {
        width: 100%;
        margin-top: 5px;
    }
</style>

<script type="text/javascript">
    require([
        'jquery',
        'mage/mage',
        'mage/validation'
    ], function ($) {
        $(document).ready(function () {
            // Get wallet balance from the HTML element
            const walletBalance = parseFloat($('#walletBalance').data('wallet-balance')) || 0;

            // Custom validation rule to check if amount exceeds wallet balance
            $.validator.addMethod(
                "walletLimit",
                function (value, element) {
                    const amount = parseFloat(value);
                    return amount <= walletBalance;
                },
                "Entered amount exceeds available wallet balance!"
            );

            // Apply Magento validation to forms
            $('#wallet-remove-money-form, .wallet-transfer-form, #wallet-add-money-form').mage('validation');

            // Attach validation to the Deduct Money and Transfer Money fields
            $('#deducted_amount, #transfer_amount').attr('data-validate', JSON.stringify({
                required: true,
                'validate-number': true,
                'min': 1,
                walletLimit: true
            }));

            // Handle tab switching
            const selectEl = $("#transaction_operations");
            const allTabs = $(".tab");

            function showTab(selectedTab) {
                allTabs.hide();
                $("." + selectedTab).show();
            }

            // Show default selected tab
            showTab(selectEl.val());

            selectEl.on("change", function () {
                showTab($(this).val());
            });
        });
    });
</script>






















