                <button type="submit" id="add-money-btn" class="action-primary">Add Money</button>
            </div>
        </form>
    </div>

    <!-- Deduct Money Form -->
    <div class="deduct_money tab">
        <form id="wallet-remove-money-form" action="<?= $block->getDeductMoneyUrl(); ?>" method="post">
            <input type="hidden" name="form_key" value="<?= $block->getFormKey(); ?>">
            <div class="field">
                <label class="label" for="deducted_amount">Enter Amount:</label>
                <input type="number" id="deducted_amount" name="amount"
                       data-validate="{required:true, 'validate-number':true, 'min':1}"
